# Build output (build/, and out-of-tree dirs build-win/ build-gcc/ build-tsan/ …)
/build/
/build-*/
*.o
*.a

# Native-compilation artifacts (--exe / --aot / --bundle)
*.gen.cpp
/a.out

# Scratch binaries and files left in the tree during development
/1
/2
/fib
/1.raku
/comb.testing
/results.json

# Test-run temp files (created by the Roast I/O tests when run from the repo root)
/temp-*
/tempfile*
/mkdir-t-testfile-*
/buffer*
/lib/
/.tmp-test-file
/async-print-tester
/parse_and_parsefile_test
/handle-between-threads-*

# RosettaCode compare harness: fetched programs (rc-cache/, keyed by task name) and
# per-run scratch (rc-work/). Cached on disk to avoid re-fetching, never tracked.
/rc-cache/
/rc-work/

# Homebrew packaging lives in the separate ash/homebrew-rakupp tap; kept here on
# disk for convenience but not tracked in this repo.
/packaging/

# Rakudo precompilation cache (created when modules are loaded)
**/.precomp/

# Editor / OS cruft
.DS_Store
*.swp

# Claude Code local config / memory notes (kept on disk, not tracked)
.claude/
.claude-memory/
build-mingw/
