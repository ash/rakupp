; Exercises the interpreter's breadth in one deterministic run — used by t/lisp.t.
(define (fact n) (if (= n 0) 1 (* n (fact (- n 1)))))
(display (list 1 2 3)) (newline)
(display (car '(1 2 3))) (newline)
(display (cdr '(1 2 3))) (newline)
(display (append '(1 2) '(3 4))) (newline)
(display (reverse '(1 2 3))) (newline)
(display (map (lambda (x) (* x x)) '(1 2 3 4))) (newline)
(display (filter odd? '(1 2 3 4 5 6))) (newline)
(display (fold-left + 0 '(1 2 3 4 5))) (newline)
(display (if (= 1 1) "yes" "no")) (newline)
(display (cond ((= 2 1) 'a) ((= 2 2) 'b) (else 'c))) (newline)
(display (let ((a 2) (b 5)) (* a b))) (newline)
(display `(the answer is ,(+ 40 2))) (newline)
(display (let ((xs '(1 2 3))) `(head ,(car xs) tail ,@(cdr xs)))) (newline)
(display (fact 20)) (newline)
