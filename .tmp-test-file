use Test;

plan 8;
my $r;

# table with no ending ws
=table
    X | O |
   ---+---+---
      | X | O
   ---+---+---
      |   | X


# table with ending ws
=table
    X | O | 
   ---+---+---
      | X | O
   ---+---+---
      |   | X


$r = $=pod[0];
is $r.contents.elems, 3;
is $r.contents[0].join(','), 'X,O,';
is $r.contents[1].join(','), ',X,O';
is $r.contents[2].join(','), ',,X';

$r = $=pod[1];
is $r.contents.elems, 3;
is $r.contents[0].join(','), 'X,O,';
is $r.contents[1].join(','), ',X,O';
is $r.contents[2].join(','), ',,X';
